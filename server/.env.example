# Copy this file to .env and fill in your values
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxxx.mongodb.net/?appName=Cluster0
JWT_SECRET=change-this-to-a-long-random-string
CLIENT_ORIGIN=http://localhost:5173

# Optional: enables the AI chatbot. Without it, a built-in rule-based
# assistant answers compatibility/stock/how-to questions instead.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5
