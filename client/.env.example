# Copy this file to .env and fill in your values
VITE_API_URL=http://localhost:5001/api

# Cloudinary unsigned upload preset — used to upload the hospital
# verification document directly from the browser.
# Create both in your Cloudinary dashboard: Settings > Upload > Upload presets
# (set "Signing Mode" to "Unsigned" on the preset).
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
